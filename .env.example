# This is an example environment file.
# Copy these to a new file named .env in your project root and replace with your actual values.
# .env files should never be committed to git as they may contain sensitive information.
# This .env.example serves as documentation for required environment variables.

# Site URL
# used for sitemap generation and robots.txt.
# In production (.env.production), set to your live domain
VITE_SITE_URL=http://localhost:5173

# Site title used for <title>, Open Graph, and Twitter cards
VITE_SITE_TITLE=wipeout3.com: React Edition

# Meta description used for <meta>, Open Graph, and Twitter cards
VITE_SITE_DESCRIPTION=A faithful JavaScript recreation of the original 1999 Wipeout 3 Flash website by The Designers Republic, Kleber, and Psygnosis.

# Web3Forms access key for the contact form.
# Optional, only needed if the contact form is enabled.
# Get a free access key at https://web3forms.com/
VITE_WEB3FORMS_ACCESS_KEY=